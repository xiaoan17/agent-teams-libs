      "args": [
        "--dangerously-skip-permissions"
      ],
      "instructions_file": "CLAUDE.md",
      "skills_dir": ".claude/skills"
    },
    "codex": {
      "command": "codex",
      "args": [
        "--dangerously-bypass-approvals-and-sandbox"
      ],
      "instructions_file": "AGENTS.md",
      "skills_dir": ".codex/skills"
    }
  },
  "collab": {
    "upstream": [
      "prd",
      "manager"
    ],
    "downstream": [
      "qa"
    ],
    "handoff_via": ".aiteam/tasks/"
  }
}
